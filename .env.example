# GREAT ENDURED TECHNOLOGY — Environment Configuration Example
# Rename this file to .env and configure for your local/production environment

# Application Config
APP_ENV=production
APP_URL=https://greatentech.com
APP_NAME="Great Endured Technology"

# Database Configuration (MySQL/MariaDB via PDO)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=greatentech_db
DB_USER=greatentech_user
DB_PASS=greatentech_password

# Security
# Generate a strong 32-character string for CSRF secret
CSRF_SECRET=your_super_secret_csrf_signing_key_here

# Mailer Settings
# If empty, defaults to PHP's standard mail() function
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=contact@greatentech.com
SMTP_FROM_NAME="Great Endured Technology"
