# RATUL Build Protocol Git Ignore

# System & IDE files
.DS_Store
Thumbs.db
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Node modules (for local build tools)
node_modules/
npm-debug.log*

# Environment and Secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
/Vault/content/.key

# Vault / Runtime files
/Vault/uploads/*
!/Vault/uploads/.gitkeep
/Vault/backups/*
!/Vault/backups/.gitkeep
/Vault/cache/*
!/Vault/cache/.gitkeep

# Setup database migrations / diff output
/Setup/db/*.sql
!/Setup/db/schema.sql
/Setup/install/*.lock

# Local distribution source directories
# Note: Keep /src in git, but do not deploy it to production shared hosting.
# Ignore compiled styles map files if generated
/Front/static/css/*.css.map
/Front/static/js/*.js.map
